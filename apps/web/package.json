{
  "name": "@labword/web",
  "version": "0.1.0",
  "private": true,
  "description": "LabWord web app (Vite SPA)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'web lint covered by root'",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@labword/app": "workspace:*",
    "@labword/domain": "workspace:*",
    "@labword/platform": "workspace:*",
    "@labword/platform-web": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}

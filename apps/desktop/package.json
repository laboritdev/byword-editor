{
  "name": "@labword/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "LabWord desktop shell (Electron)",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node ./node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint ../../packages ../../apps/web/src --max-warnings=0",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@labword/app": "workspace:*",
    "@labword/domain": "workspace:*",
    "@labword/platform": "workspace:*",
    "@labword/platform-electron": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.2.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}

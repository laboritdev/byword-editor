{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@labword/domain/*": ["../../packages/domain/src/*"],
      "@labword/platform-electron/*": ["../../packages/platform-electron/src/*"]
    }

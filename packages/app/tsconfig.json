{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@labword/app/*": ["src/*"],
      "@labword/domain/*": ["../domain/src/*"],
      "@labword/platform": ["../platform/src/index.ts"],
      "@labword/platform/*": ["../platform/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
